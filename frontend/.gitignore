cat > .gitignore << 'EOF'
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production build
dist/
build/

# Vite
.vite/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

EOF